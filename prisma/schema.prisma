generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  PAID
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum SectionType {
  TEXT
  PRICING
  IMAGE
  DIVIDER
  HEADING
}

enum Plan {
  FREE
  PRO
  AGENCY
}

enum BusinessCategory {
  FREELANCER
  LANDLORD
  AGENCY
}

enum LeaseStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  EXPIRED
  CANCELLED
}

enum LeasePaymentType {
  DEPOSIT
  RENT
}

enum AuditAction {
  USER_REGISTERED
  USER_LOGIN
  USER_LOGIN_FAILED
  EMAIL_VERIFIED
  EMAIL_VERIFICATION_SENT
  PASSWORD_RESET
  ACCOUNT_DELETED
  PROPOSAL_PUBLISHED
  PROPOSAL_VIEWED
  PROPOSAL_SIGNED
  PROPOSAL_PAYMENT_INITIATED
  LEASE_CREATED
  LEASE_PUBLISHED
  LEASE_SIGNED
  LEASE_PAYMENT_INITIATED
  LEASE_DOCUMENT_ACCESSED
  LEASE_DOCUMENT_UPLOADED
  STRIPE_WEBHOOK
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  name            String?
  passwordHash    String?
  image           String?
  emailVerified   DateTime?
  plan            Plan       @default(FREE)
  businessCategory BusinessCategory?
  stripeCustomerId String?   @unique

  // Stripe Connect — freelancer's payout account
  stripeConnectId        String?  @unique  // acct_xxx
  stripeConnectOnboarded Boolean  @default(false)

  proposals       Proposal[]
  leases          Lease[]
  accounts        Account[]
  sessions        Session[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([email])
}

model Proposal {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  clientName      String
  clientEmail     String
  status          ProposalStatus  @default(DRAFT)

  // Shareable token — generated on publish
  token           String?         @unique
  expiresAt       DateTime?

  // Payment config
  depositAmount   Int?            // in cents
  currency        String          @default("usd")

  // Contract body (HTML/markdown)
  contractBody    String?

  sections        ProposalSection[]
  contract        Contract?
  payment         Payment?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([token])
  @@index([status])
}

model ProposalSection {
  id          String      @id @default(cuid())
  proposalId  String
  proposal    Proposal    @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  type        SectionType
  order       Int
  content     Json        // flexible per type

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([proposalId, order])
}

model Contract {
  id              String    @id @default(cuid())
  proposalId      String    @unique
  proposal        Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  // Signer info (filled by client)
  signerName      String?
  signerEmail     String?
  signatureData   String?   // base64 PNG of drawn signature
  signedAt        DateTime?
  ipAddress       String?
  userAgent       String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Payment {
  id                    String        @id @default(cuid())
  proposalId            String        @unique
  proposal              Proposal      @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  stripeSessionId       String?       @unique
  stripePaymentIntentId String?       @unique
  amount                Int           // in cents
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  paidAt                DateTime?

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

// ─── Lease ────────────────────────────────────────────────────────────────────

model Lease {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Property
  propertyAddress String
  unitNumber      String?

  // Tenant
  tenantName      String
  tenantEmail     String

  // Financial
  monthlyRent     Int           // cents
  depositAmount   Int?          // cents (null = no deposit)
  currency        String        @default("usd")

  // Dates
  leaseStart      DateTime
  leaseEnd        DateTime

  // Document — PDF upload (Vercel Blob) or text
  leaseDocUrl     String?
  contractBody    String?

  // Existing tenants: skip the e-sign step, go straight to payments
  skipSigning     Boolean       @default(false)

  // Status + cryptographically secure share token (set at creation, rotated on publish)
  status          LeaseStatus   @default(DRAFT)
  token           String        @unique

  // Stripe subscription ID (set after tenant subscribes)
  stripeSubId     String?       @unique

  leaseContract   LeaseContract?
  leasePayments   LeasePayment[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([token])
  @@index([status])
}

model LeaseContract {
  id            String   @id @default(cuid())
  leaseId       String   @unique
  lease         Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  signerName    String
  signerEmail   String
  signatureData String   // base64 PNG
  signedAt      DateTime @default(now())
  ipAddress     String?

  createdAt     DateTime @default(now())
}

model LeasePayment {
  id              String           @id @default(cuid())
  leaseId         String
  lease           Lease            @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  type            LeasePaymentType
  amount          Int              // cents
  currency        String           @default("usd")

  stripeSessionId String?          @unique
  stripeInvoiceId String?          @unique

  status          PaymentStatus    @default(PENDING)
  dueDate         DateTime?
  paidAt          DateTime?

  createdAt       DateTime         @default(now())

  @@index([leaseId])
}

// ─── NextAuth ─────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Security ─────────────────────────────────────────────────────────────────

model RateLimitBucket {
  key       String   @id
  count     Int      @default(1)
  expiresAt DateTime

  @@index([expiresAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  action       AuditAction
  actorId      String?
  actorEmail   String?
  resourceType String?
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}
