# ─── Supabase (use pact_app role — not postgres superuser) ───
# Local dev: direct URL (db.[ref].supabase.co) with pact_app
DATABASE_URL="postgresql://pact_app.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"
DIRECT_URL="postgresql://pact_app.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"
# Vercel/serverless: postgres pooler password from Supabase Dashboard → Settings → Database
SUPABASE_POSTGRES_PASSWORD=""

# Not used by the app (Prisma only) — safe to omit in production
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ─── Auth ───────────────────────────────────────────────────
# Set both to the same value (generate with: openssl rand -base64 32)
AUTH_SECRET=""
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="https://your-app.vercel.app"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Optional — not used by current Checkout flow
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── Email (Resend) ─────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="Pact <onboarding@resend.dev>"
EMAIL_REPLY_TO="use.pact.features@gmail.com"

# ─── Vercel Blob (lease PDF uploads) ────────────────────────
# Create in Vercel → Storage → Blob
BLOB_READ_WRITE_TOKEN=""

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
